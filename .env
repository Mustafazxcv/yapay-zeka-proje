# NewsData.io API anahtari
NEWSDATA_API_KEY=pub_5634fd48872146899c598f0e4a958fc9

# Aranacak haber konusu (ornek: technology, business, science)
NEWS_QUERY=technology

# Dil kodu (Ingilizce icin: en)
NEWS_LANGUAGE=en

# Ulke kodu (ABD icin: us)
NEWS_COUNTRY=us

# Kategori filtresi (bos birakilabilir)
NEWS_CATEGORY=

# En fazla kac sayfa veri cekilecegi
NEWS_MAX_PAGES=3

# JSON cikti dosyasi yolu
NEWS_OUT_JSON=data/headlines_newsdata.json

# CSV cikti dosyasi yolu
NEWS_OUT_CSV=data/headlines_newsdata.csv

# true ise eski veriyi korur, yeni veriyi ekler ve tekrar kayitlari temizler
NEWS_APPEND_MODE=true

#------------------------------------------------------------------------------------------------

# NewsAPI API anahtari
NEWSAPI_API_KEY=7dc6eb344e0f423890c131c13b0dbb23

# Aranacak haber konusu (bos ise country/category kullanilir)
NEWSAPI_QUERY=technology

# Dil kodu (query kullanildiginda gecerli)
NEWSAPI_LANGUAGE=en

# Ulke kodu (query bos ise kullanilir)
NEWSAPI_COUNTRY=us

# Kategori (query bos ise kullanilir)
NEWSAPI_CATEGORY=

# Sayfa basi cekilecek haber sayisi (NewsAPI en fazla 100)
NEWSAPI_PAGE_SIZE=50

# En fazla kac sayfa veri cekilecegi
NEWSAPI_MAX_PAGES=30

# Kaynak bazli genisletmede en fazla kac kaynak denenecegi
NEWSAPI_MAX_SOURCES=20

# NewsAPI JSON cikti dosyasi yolu
NEWSAPI_OUT_JSON=data/headlines_newsapi.json

# NewsAPI CSV cikti dosyasi yolu
NEWSAPI_OUT_CSV=data/headlines_newsapi.csv

# true ise eski veriyi korur, yeni veriyi ekler ve tekrar kayitlari temizler
NEWSAPI_APPEND_MODE=true

# true ise kaynak listesi uzerinden ek basliklar cekerek veri hacmini artirir
NEWSAPI_EXPAND_SOURCES=true
