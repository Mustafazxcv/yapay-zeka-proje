# NewsData.io API anahtari
NEWSDATA_API_KEY=pub_5634fd48872146899c598f0e4a958fc9

# Aranacak haber konusu (ornek: technology, business, science)
NEWS_QUERY=technology

# Dil kodu (sabit: en)
NEWS_LANGUAGE=en

# Ulke kodu (sabit: us)
NEWS_COUNTRY=us

# Kategori filtresi (bos birakilabilir)
NEWS_CATEGORY=

# En fazla kac sayfa veri cekilecegi
NEWS_MAX_PAGES=3

# JSON cikti dosyasi yolu (tum kaynaklar tek dosyada birlesir)
NEWS_OUT_JSON=data/all/headlines_all.json

# CSV cikti dosyasi yolu (tum kaynaklar tek dosyada birlesir)
NEWS_OUT_CSV=data/all/headlines_all.csv

# true ise eski veriyi korur, yeni veriyi ekler ve tekrar kayitlari temizler
NEWS_APPEND_MODE=true

#------------------------------------------------------------------------------------------------

# NewsAPI API anahtari
NEWSAPI_API_KEY=7dc6eb344e0f423890c131c13b0dbb23

# Aranacak haber konusu (bos ise country/category kullanilir)
NEWSAPI_QUERY=technology

# Dil kodu (sabit: en)
NEWSAPI_LANGUAGE=en

# Ulke kodu (sabit: us)
NEWSAPI_COUNTRY=us

# Kategori (query bos ise kullanilir)
NEWSAPI_CATEGORY=

# Sayfa basi cekilecek haber sayisi (NewsAPI en fazla 100)
NEWSAPI_PAGE_SIZE=50

# En fazla kac sayfa veri cekilecegi
NEWSAPI_MAX_PAGES=30

# Kaynak bazli genisletmede en fazla kac kaynak denenecegi
NEWSAPI_MAX_SOURCES=20

# NewsAPI JSON cikti dosyasi yolu (tum kaynaklar tek dosyada birlesir)
NEWSAPI_OUT_JSON=data/all/headlines_all.json

# NewsAPI CSV cikti dosyasi yolu (tum kaynaklar tek dosyada birlesir)
NEWSAPI_OUT_CSV=data/all/headlines_all.csv

# true ise eski veriyi korur, yeni veriyi ekler ve tekrar kayitlari temizler
NEWSAPI_APPEND_MODE=true

# true ise kaynak listesi uzerinden ek basliklar cekerek veri hacmini artirir
NEWSAPI_EXPAND_SOURCES=true

#------------------------------------------------------------------------------------------------

# Google arama tabanli konu botu ayarlari
# Virgulle ayrilmis konu listesi
TOPIC_RSS_TOPICS=technology,artificial intelligence,machine learning,data science,cybersecurity,cloud computing,software engineering,startups,fintech,cryptocurrency,stock market,global economy,business,innovation,robotics,semiconductors,quantum computing,electric vehicles,renewable energy,space technology,biotechnology,healthcare,climate change,geopolitics,world news

# Arama dili (sabit: en)
TOPIC_RSS_LANGUAGE=en

# Arama ulkesi (sabit: US)
TOPIC_RSS_COUNTRY=US

# Sayfa basi sonuc sayisi (1-100)
TOPIC_RSS_RESULTS_PER_PAGE=100

# Konu basi en fazla istek limiti (guvenlik limiti)
TOPIC_RSS_MAX_REQUESTS_PER_TOPIC=200

# Google tarama JSON cikti dosyasi yolu (tum kaynaklar tek dosyada birlesir)
TOPIC_RSS_OUT_JSON=data/all/headlines_all.json

# Google tarama CSV cikti dosyasi yolu (tum kaynaklar tek dosyada birlesir)
TOPIC_RSS_OUT_CSV=data/all/headlines_all.csv

# true ise eski veriyi korur, yeni veriyi ekler ve tekrar kayitlari temizler
TOPIC_RSS_APPEND_MODE=true

# true ise Chromium penceresi acilarak insan gibi tarama yapilir
TOPIC_RSS_SHOW_BROWSER=true
