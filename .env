# NewsData.io API anahtari
NEWSDATA_API_KEY=pub_947166f132b44ba581d18051cc43ff73

# Aranacak haber konusu (ornek: ekonomi, spor, teknoloji)
NEWS_QUERY=teknoloji

# Dil kodu (Turkce icin: tr)
NEWS_LANGUAGE=tr

# Ulke kodu (Turkiye icin: tr)
NEWS_COUNTRY=tr

# Kategori filtresi (bos birakilabilir)
NEWS_CATEGORY=

# En fazla kac sayfa veri cekilecegi
NEWS_MAX_PAGES=10

# JSON cikti dosyasi yolu
NEWS_OUT_JSON=data/headlines_raw.json

# CSV cikti dosyasi yolu
NEWS_OUT_CSV=data/headlines_raw.csv

# true ise eski veriyi korur, yeni veriyi ekler ve tekrar kayitlari temizler
NEWS_APPEND_MODE=true
